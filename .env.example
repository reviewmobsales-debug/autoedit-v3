# AutoEdit Environment Variables
# Copy to .env and fill in

# Server
PORT=5002
FLASK_ENV=production

# Optional: Whisper model size (tiny, base, small, medium, large)
WHISPER_MODEL=base

# Optional: Pexels API key for B-roll
PEXELS_API_KEY=your_key_here

# Optional: Cloudflare tunnel token
CLOUDFLARE_TUNNEL_TOKEN=

# Optional: Railway/Render/Fly deploy tokens
RAILWAY_TOKEN=
FLY_API_TOKEN=
RENDER_API_KEY=
